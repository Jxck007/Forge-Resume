rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCurrentUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasValidOwner(data) {
      return data.keys().hasAll(['ownerId'])
        && data.ownerId is string
        && data.ownerId == request.auth.uid;
    }

    function hasValidResumeIdentity(data, resumeId) {
      return data.keys().hasAll(['id', 'ownerId'])
        && data.id is string
        && data.id == resumeId
        && hasValidOwner(data);
    }

    function hasValidAtsReport(data, reportId) {
      return data.keys().hasAll(['id', 'userId'])
        && data.id is string
        && data.id == reportId
        && data.userId is string
        && data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isCurrentUser(userId);
    }

    match /profiles/{userId} {
      allow read: if isCurrentUser(userId);
      allow create, update: if isCurrentUser(userId)
        && request.resource.data.keys().hasAll(['uid'])
        && request.resource.data.uid == userId;
      allow delete: if isCurrentUser(userId);
    }

    match /resumes/{resumeId} {
      function resumeOwnedByCurrentUser(data) {
        return (data.ownerId == request.auth.uid || data.userId == request.auth.uid)
          && data.ownerId == data.userId;
      }

      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['id', 'ownerId', 'userId'])
        && request.resource.data.id == resumeId
        && resumeOwnedByCurrentUser(request.resource.data);

      allow read, delete: if isSignedIn()
        && resource.data.keys().hasAny(['ownerId', 'userId'])
        && resumeOwnedByCurrentUser(resource.data);

      allow update: if isSignedIn()
        && resource.data.keys().hasAny(['ownerId', 'userId'])
        && resumeOwnedByCurrentUser(resource.data)
        && request.resource.data.keys().hasAll(['id', 'ownerId', 'userId'])
        && request.resource.data.id == resumeId
        && resumeOwnedByCurrentUser(request.resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.userId == resource.data.userId;
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['userId', 'category', 'message', 'route', 'timestamp'])
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    match /atsReports/{reportId} {
      allow create: if isSignedIn()
        && hasValidAtsReport(request.resource.data, reportId);
      allow read, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /aiUsage/{document=**} {
      allow read, write: if false;
    }

    match /aiAbuse/{document=**} {
      allow read, write: if false;
    }

    match /aiSystem/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
