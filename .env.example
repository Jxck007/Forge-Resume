# ------------------------------
# Client: Firebase web app config
# ------------------------------
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890
VITE_APP_VERSION=beta

# ------------------------------
# Server: Forge Free Beta AI toggle
# ------------------------------
AI_FREE_BETA_ENABLED=false

# ------------------------------
# Server: AI providers
# Set only the providers you plan to use
# ------------------------------
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
CEREBRAS_API_KEY=your_cerebras_api_key

# ------------------------------
# Server: Upstash quota / abuse protection
# Required for Forge Free Beta AI quota tracking
# ------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
AI_ABUSE_HASH_SALT=replace_with_a_long_random_string

# ------------------------------
# Server: Optional Firebase Admin credentials
# Add only if your deployment uses Firebase Admin routes
# ------------------------------
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
